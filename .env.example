ENVIRONMENT=development

HTTP_PORT=3000
WEBSOCKET_PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knex_flow

DB_TYPE=postgres
DB_HOST=knex-flow-database
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=knex_flow
DB_SYNCHRONIZE=true
DB_TIMEZONE=America/Sao_Paulo

ORM_ENTITIES_PATH=/../modules/**/infra/orm/entities/*.js

BULLMQ_HOST=knex-flow-redis
BULLMQ_PORT=6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

ABACATEPAY_API_KEY=
ABACATEPAY_API_URL=
ABACATEPAY_SECRET=

WEBSOCKET_RATE_LIMIT_MAX_MESSAGES=5
WEBSOCKET_RATE_LIMIT_WINDOW_MS=10000

MINIO_ENDPOINT=knex-flow-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000
