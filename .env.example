ENVIRONMENT=development

HTTP_PORT=3000
WEBSOCKET_PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knex_flow

DB_TYPE=postgres
DB_HOST=knex-flow-database
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=knex_flow
DB_SYNCHRONIZE=true
DB_TIMEZONE=America/Sao_Paulo
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000

ORM_ENTITIES_PATH=/../modules/**/infra/orm/entities/*.js

BULLMQ_HOST=knex-flow-redis
BULLMQ_PORT=6379
BULLMQ_WORKER_CONCURRENCY=1
BULLMQ_JOB_ATTEMPTS=3
BULLMQ_JOB_BACKOFF_DELAY_MS=1000
BULLMQ_REMOVE_ON_COMPLETE_AGE=3600
BULLMQ_REMOVE_ON_COMPLETE_COUNT=1000
BULLMQ_REMOVE_ON_FAIL_AGE=604800
BULLMQ_REMOVE_ON_FAIL_COUNT=5000

ORDER_PENDING_TTL_MINUTES=30
ORDER_EXPIRATION_INTERVAL_MS=60000
REFUND_WINDOW_DAYS=2

JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

ABACATEPAY_API_KEY=
ABACATEPAY_API_URL=
ABACATEPAY_SECRET=
ABACATEPAY_PIX_EXPIRES_IN=300

WEBSOCKET_RATE_LIMIT_MAX_MESSAGES=5
WEBSOCKET_RATE_LIMIT_WINDOW_MS=10000

MINIO_ENDPOINT=knex-flow-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=files

MAILER_API_KEY=
MAILER_API_URL=https://api.resend.com/emails
MAILER_FROM=Knex Flow <onboarding@resend.dev>

DISCORD_ERROR_WEBHOOK_URL=