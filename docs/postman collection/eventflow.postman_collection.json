{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Eventflow API",
    "description": "Rotas alinhadas ao backend (`src/shared/infra/http/routes/index.ts`). Use `baseUrl` e `token` (variáveis de coleção ou ambiente). Login/Register/Refresh e Health não usam Bearer; o restante usa o auth da coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Público (antes do `authMiddleware`)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code !== 200 && pm.response.code !== 201) return;",
                  "let body;",
                  "try { body = pm.response.json(); } catch (e) { return; }",
                  "const token = body.token || body.access_token || body.accessToken || (body.data && (body.data.token || body.data.access_token));",
                  "if (token) {",
                  "  if (pm.environment.get('baseUrl') !== undefined) pm.environment.set('token', token);",
                  "  else pm.collectionVariables.set('token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "`celebrate`: email (string email), password (min 6)."
          },
          "response": []
        },
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "`celebrate`: email, password (min 6)."
          },
          "response": []
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<paste-refresh-token>\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "`celebrate`: refreshToken (string obrigatório)."
          },
          "response": []
        }
      ]
    },
