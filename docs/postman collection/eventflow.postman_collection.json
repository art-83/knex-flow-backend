{
  "info": {
    "_postman_id": "00000000-0000-4000-8000-000000000001",
    "name": "Eventflow API (boilerplate)",
    "description": "Boilerplate: importe os ambientes Local e PROD (pasta `postman collection`). Selecione o ambiente no canto superior direito do Postman. `baseUrl` e `token` vêm do ambiente ativo; a coleção mantém valores por defeito se não houver ambiente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (exemplo — ajustar path e body)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code !== 200 && pm.response.code !== 201) {",
                  "  console.warn('Login não OK:', pm.response.code);",
                  "  return;",
                  "}",
                  "let body;",
                  "try { body = pm.response.json(); } catch (e) {",
                  "  console.warn('Resposta não é JSON; defina o token manualmente na coleção.');",
                  "  return;",
                  "}",
                  "const token =",
                  "  body.token ||",
                  "  body.access_token ||",
                  "  body.accessToken ||",
                  "  (body.data && (body.data.token || body.data.access_token || body.data.accessToken));",
                  "if (token) {",
                  "  if (pm.environment.get('baseUrl') !== undefined) {",
                  "    pm.environment.set('token', token);",
                  "    console.log('Token guardado na variável de ambiente \"token\".');",
                  "  } else {",
                  "    pm.collectionVariables.set('token', token);",
                  "    console.log('Token guardado na variável de coleção \"token\" (sem ambiente ativo).');",
                  "  }",
                  "} else {",
                  "  console.warn('Nenhum token encontrado no JSON. Ajuste o script ao formato da API.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"change-me\"\n}\n"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Altere o path (ex.: /v1/auth/login) e o corpo conforme o contrato real do backend."
          },
          "response": []
        }
      ]
    }
  ]
}
