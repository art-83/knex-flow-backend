    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 200 || pm.response.code >= 300) return;",
                  "let body;",
                  "try { body = pm.response.json(); } catch (e) { return; }",
                  "const accessToken = body.accessToken || body.access_token || body.token || (body.data && (body.data.accessToken || body.data.access_token || body.data.token));",
                  "const refreshToken = body.refreshToken || body.refresh_token || (body.data && (body.data.refreshToken || body.data.refresh_token));",
                  "if (accessToken) {",
                  "  pm.collectionVariables.set('token', accessToken);",
                  "  if (pm.environment.get('token') !== undefined) pm.environment.set('token', accessToken);",
                  "}",
                  "if (refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', refreshToken);",
                  "  if (pm.environment.get('refreshToken') !== undefined) pm.environment.set('refreshToken', refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 200 || pm.response.code >= 300) return;",
                  "let body;",
                  "try { body = pm.response.json(); } catch (e) { return; }",
                  "const accessToken = body.accessToken || body.access_token || body.token || (body.data && (body.data.accessToken || body.data.access_token || body.data.token));",
                  "const refreshToken = body.refreshToken || body.refresh_token || (body.data && (body.data.refreshToken || body.data.refresh_token));",
                  "if (accessToken) {",
                  "  pm.collectionVariables.set('token', accessToken);",
                  "  if (pm.environment.get('token') !== undefined) pm.environment.set('token', accessToken);",
                  "}",
                  "if (refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', refreshToken);",
                  "  if (pm.environment.get('refreshToken') !== undefined) pm.environment.set('refreshToken', refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 200 || pm.response.code >= 300) return;",
                  "let body;",
                  "try { body = pm.response.json(); } catch (e) { return; }",
                  "const accessToken = body.accessToken || body.access_token || body.token || (body.data && (body.data.accessToken || body.data.access_token || body.data.token));",
                  "if (accessToken) {",
                  "  pm.collectionVariables.set('token', accessToken);",
                  "  if (pm.environment.get('token') !== undefined) pm.environment.set('token', accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          },
          "response": []
        }
      ]
    },
