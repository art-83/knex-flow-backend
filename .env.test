ENVIRONMENT=test

HTTP_PORT=3000
WEBSOCKET_PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knex_flow_test

DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=knex_flow_test
DB_SYNCHRONIZE=true
DB_TIMEZONE=America/Sao_Paulo
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000

ORM_ENTITIES_PATH=/../../dist/modules/**/infra/orm/entities/*.js

BULLMQ_HOST=localhost
BULLMQ_PORT=6380
BULLMQ_WORKER_CONCURRENCY=1
BULLMQ_JOB_ATTEMPTS=3
BULLMQ_JOB_BACKOFF_DELAY_MS=1000
BULLMQ_REMOVE_ON_COMPLETE_AGE=3600
BULLMQ_REMOVE_ON_COMPLETE_COUNT=1000
BULLMQ_REMOVE_ON_FAIL_AGE=604800
BULLMQ_REMOVE_ON_FAIL_COUNT=5000

ORDER_PENDING_TTL_MINUTES=30
ORDER_EXPIRATION_INTERVAL_MS=60000
REFUND_WINDOW_DAYS=2

JWT_SECRET=test-jwt-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=test-jwt-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

ABACATEPAY_API_KEY=test-api-key
ABACATEPAY_API_URL=http://localhost:9999
ABACATEPAY_SECRET=test-webhook-secret
WEBSOCKET_RATE_LIMIT_MAX_MESSAGES=5
WEBSOCKET_RATE_LIMIT_WINDOW_MS=10000

MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9002
MINIO_BUCKET=files-test

MAILER_API_KEY=test-mailer-key
MAILER_API_URL=http://localhost:9998/emails
MAILER_FROM=Knex Flow Test <test@example.com>

DISCORD_ERROR_WEBHOOK_URL=http://localhost:9997/webhook
