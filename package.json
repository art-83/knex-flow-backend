{
  "name": "knex-flow-backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/shared/http/server.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "seed:local-admin": "node scripts/seed-local-admin.mjs",
    "worker:payment-processing-queue": "node dist/shared/infra/queue/queue-bootstrap.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint -c .husky/mjs/eslint.config.mjs src/",
    "standardize-exports": "node .husky/mjs/standardize-exports.mjs",
    "commitlint": "commitlint --config .husky/mjs/commitlint.config.mjs --edit",
    "test": "vitest run --config tests/config/vitest.unit.config.ts && vitest run --config tests/config/vitest.integration.config.ts && vitest run --config tests/config/vitest.e2e.config.ts",
    "test:unit": "vitest run --config tests/config/vitest.unit.config.ts",
    "test:integration": "vitest run --config tests/config/vitest.integration.config.ts",
    "test:e2e": "vitest run --config tests/config/vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage --config tests/config/vitest.unit.config.ts && vitest run --coverage --config tests/config/vitest.integration.config.ts",
    "test:k6": "k6 run tests/k6/smoke.js",
    "test:smoke-server": "TS_NODE_PROJECT=tests/tsconfig.json TS_NODE_TRANSPILE_ONLY=true node -r ts-node/register tests/scripts/start-test-server.ts",
    "prepare": "node -e \"const fs=require('fs');const {execFileSync}=require('child_process');const p=require('path');const b=p.join('node_modules','husky','bin.js');if(fs.existsSync(b))execFileSync(process.execPath,[b],{stdio:'inherit'})\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@swc/core": "^1.15.26",
    "@swc/helpers": "^0.5.21",
    "@testcontainers/postgresql": "^12.0.3",
    "@testcontainers/redis": "^12.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/nock": "^10.0.3",
    "@types/node": "^25.5.2",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "nock": "^14.0.15",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "minio": "^8.0.7",
    "multer": "^2.2.0",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.28",
    "uuid": "^11.1.1"
  }
}
